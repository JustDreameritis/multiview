# multiview API keys (all free tier)
# Run 'multiview setup' for guided configuration

# Groq - Security & Architecture reviewers
# Get key: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_key

# Mistral - Performance reviewer
# Get key: https://console.mistral.ai/api-keys
MISTRAL_API_KEY=your_mistral_key

# Google Gemini - Edge Cases reviewer
# Get key: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_key

# OpenRouter - Deep Reasoning reviewer (DeepSeek R1)
# Get key: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_key

# HuggingFace - Code Quality reviewer
# Get key: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=hf_your_huggingface_key
